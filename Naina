<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Naina Beauty Parlour</title>

<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Arial,sans-serif;
scroll-behavior:smooth;
}

body{
background:#111;
color:white;
}

nav{
display:flex;
justify-content:space-between;
align-items:center;
padding:20px 10%;
background:black;
position:sticky;
top:0;
}

nav h2{
color:#ff69b4;
}

nav ul{
display:flex;
gap:20px;
list-style:none;
}

nav ul li a{
color:white;
text-decoration:none;
}

.hero{
height:100vh;
display:flex;
flex-direction:column;
justify-content:center;
align-items:center;
text-align:center;
padding:20px;
background:linear-gradient(rgba(0,0,0,0.5),rgba(0,0,0,0.5)),
url('https://images.unsplash.com/photo-1521590832167-7bcbfaa6381f?q=80&w=1200');
background-size:cover;
background-position:center;
}

.hero h1{
font-size:60px;
}

.hero span{
color:#ff69b4;
}

.hero p{
margin-top:15px;
font-size:18px;
max-width:600px;
color:#eee;
}

.btn{
margin-top:25px;
padding:12px 30px;
background:#ff69b4;
border:none;
border-radius:30px;
color:white;
text-decoration:none;
}

section{
padding:80px 10%;
}

.title{
text-align:center;
font-size:40px;
margin-bottom:40px;
color:#ff69b4;
}

.services{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(220px,1fr));
gap:25px;
}

.card{
background:#1d1d1d;
padding:30px;
border-radius:15px;
text-align:center;
transition:0.3s;
}

.card:hover{
transform:translateY(-8px);
}

.gallery{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
gap:20px;
}

.gallery img{
width:100%;
height:250px;
object-fit:cover;
border-radius:15px;
}

.contact{
text-align:center;
}

footer{
background:black;
padding:20px;
text-align:center;
color:#aaa;
}

</style>
</head>
<body>

<nav>
<h2>Naina Beauty</h2>

<ul>
<li><a href="#about">About</a></li>
<li><a href="#services">Services</a></li>
<li><a href="#gallery">Gallery</a></li>
<li><a href="#contact">Contact</a></li>
</ul>
</nav>

